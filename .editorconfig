root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
continuation_indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[*.{kt,kts}]
ij_kotlin_allow_trailing_comma = true
ij_kotlin_binary_expression_wrap = normal
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^\n,android.**,org.**,com.**
ktlint_code_style = ktlint_official
