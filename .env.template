# Abrolhos Application Environment Variables Template
# Copy this file to local.env and fill in the values

# Application Configuration
APPLICATION_NAME=abrolhos

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/abrolhos
DB_USERNAME=abrolhos
DB_PASSWORD=abrolhos
FLYWAY_BASELINE_ON_MIGRATE=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=br.dev.demoraes

# Spring Configuration
SPRING_DATA_WEB_PAGEABLE_PAGE_SERIALIZATION_MODE=via-dto

# Management Endpoints
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINTS_HEALTH_PROBES_ENABLED=true

# Legacy CORS Configuration (deprecated - use SECURITY_CORS_ALLOWED_ORIGINS)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================================
# SECURITY HARDENING CONFIGURATION
# ============================================================================

# CORS Configuration (Requirement 6.1)
# Comma-separated list of allowed origins
# Example: https://app.example.com,https://admin.example.com
# WARNING: Wildcards (*) are not allowed in production
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting Configuration (Requirement 6.2)
# Maximum number of requests allowed within the time window
SECURITY_RATE_LIMIT_MAX_REQUESTS=5
# Time window in minutes for rate limiting
SECURITY_RATE_LIMIT_WINDOW_MINUTES=15

# Encryption Configuration (Requirement 6.3)
# Base64-encoded AES-256 encryption key for TOTP secrets
# REQUIRED: Must be at least 256 bits (32 bytes)
# Generate using: kotlin scripts/GenerateEncryptionKey.kt
# IMPORTANT: Keep this key secure and never commit it to version control
SECURITY_ENCRYPTION_KEY=

# Optional: Comma-separated list of old encryption keys for key rotation
# Used when rotating encryption keys to decrypt old data
# SECURITY_ENCRYPTION_OLD_KEYS=old_key_1,old_key_2

# Redis Configuration for Rate Limiting (Requirement 2.8)
# Redis host for distributed rate limiting
SPRING_DATA_REDIS_HOST=localhost
# Redis port
SPRING_DATA_REDIS_PORT=6379
# Redis password (optional, leave empty if no password)
SPRING_DATA_REDIS_PASSWORD=

# ============================================================================
# ENVIRONMENT-SPECIFIC NOTES
# ============================================================================

# Development:
# - Use localhost origins for CORS
# - Use a test encryption key (but still generate a proper one)
# - Redis can run locally via Docker

# Production:
# - NEVER use wildcard (*) in CORS origins
# - Generate a strong, unique encryption key
# - Use a managed Redis instance for high availability
# - Store encryption key in a secure secrets manager (e.g., AWS Secrets Manager)
# - Enable Redis authentication with a strong password
