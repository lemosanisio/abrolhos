<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    
    <conversionRule conversionWord="redactedMsg" converterClass="br.dev.demoraes.abrolhos.infrastructure.web.config.SensitiveDataRedactorConverter" />
    <!-- Dev/default profile: human-readable console + file output -->
    <springProfile name="!production">
        <!-- Console appender for application logs -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId}] [%thread] %-5level %logger{36} - %redactedMsg%n</pattern>
            </encoder>
        </appender>
        
        <!-- File appender for application logs with rotation -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/application.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId}] [%thread] %-5level %logger{36} - %redactedMsg%n</pattern>
            </encoder>
        </appender>
        
        <!-- Separate audit log file with rotation -->
        <!-- Requirement 5.6, 5.7: Separate audit log with 90-day retention -->
        <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/audit.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/audit.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>90</maxHistory> <!-- 90-day retention for compliance -->
            </rollingPolicy>
            <encoder>
                <!-- Raw JSON output, no extra formatting -->
                <pattern>%redactedMsg%n</pattern>
            </encoder>
        </appender>
        
        <!-- Async appender for non-blocking audit writes -->
        <!-- Requirement 5.7: Async logging for performance -->
        <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="AUDIT_FILE" />
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold> <!-- Never discard audit events -->
            <includeCallerData>false</includeCallerData> <!-- Performance optimization -->
        </appender>
        
        <!-- Audit logger configuration -->
        <!-- Requirement 5.6: Structured JSON format in separate file -->
        <logger name="AUDIT" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_AUDIT" />
        </logger>
        
        <!-- Root logger configuration -->
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
        </root>
        
        <!-- Spring Boot specific loggers -->
        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.hibernate" level="WARN"/>
    </springProfile>

    <!-- Production profile: structured JSON logging (compatible with VictoriaLogs) -->
    <springProfile name="production">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="org.springframework.boot.logging.logback.StructuredLogEncoder">
                <format>ecs</format>
            </encoder>
        </appender>

        <!-- Audit logs also in JSON format for production -->
        <appender name="AUDIT_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/audit.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/audit.%d{yyyy-MM-dd}.log</fileNamePattern>
                <maxHistory>90</maxHistory>
            </rollingPolicy>
            <encoder class="org.springframework.boot.logging.logback.StructuredLogEncoder">
                <format>ecs</format>
            </encoder>
        </appender>

        <appender name="ASYNC_AUDIT_JSON" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="AUDIT_JSON" />
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>false</includeCallerData>
        </appender>

        <logger name="AUDIT" level="INFO" additivity="false">
            <appender-ref ref="ASYNC_AUDIT_JSON" />
        </logger>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE" />
        </root>

        <logger name="org.springframework.web" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
        <logger name="org.hibernate" level="WARN"/>
    </springProfile>

</configuration>

